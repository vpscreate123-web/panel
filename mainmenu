        let "percent = i * 100 / duration"
        let "filled = i * width / duration"
        let "empty = width - filled"
        
        printf "\r${W} [${G}"
        printf "%${filled}s" | tr ' ' 'в– '
        printf "${DIM}"
        printf "%${empty}s" | tr ' ' 'в–Ў'
