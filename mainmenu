# ---- PTERODACTYL MENU (Keep original logic) ----
ptero_menu() {
    while true; do
        clear
        echo -e "${C}=========================================${N}"
        echo -e "   ${W}PTERODACTYL CONTROL CENTER v2.1${N}"
        echo -e "${C}=========================================${N}"
        echo ""
        echo "1) Install Panel"
        echo "2) Create User"
        echo "3) Update Panel"
        echo "4) Install SSL"
        echo "5) Uninstall Panel"
        echo "6) Back to Main Menu"
        echo ""
        read -p "Select option: " opt

        case $opt in
            1) bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/install.sh) ; pause ;;
            2) cd /var/www/pterodactyl 2>/dev/null && php artisan p:user:make ; pause ;;
            3)
                cd /var/www/pterodactyl || { echo "Panel not installed!"; sleep 2; continue; }
                php artisan down
                curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz
                tar -xzvf panel.tar.gz
                COMPOSER_ALLOW_SUPERUSER=1 composer install --no-dev --optimize-autoloader
                php artisan migrate --seed --force
                php artisan up
                pause
                ;;
            4) bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/ssl.sh) ; pause ;;
            5) rm -rf /var/www/pterodactyl ; echo "Panel Removed." ; sleep 2 ;;
            6) break ;;
            *) echo "Invalid option" ; sleep 1 ;;
        esac
    done
}

